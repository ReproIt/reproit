{
  "name": "reproit-react-native",
  "version": "1.0.0",
  "description": "ReproIt production telemetry SDK for React Native: emits the same state-graph + error events as the reproit test runners, so production data aligns 1:1 with test data.",
  "license": "Apache-2.0",
  "author": "ReproIt, Inc.",
  "homepage": "https://reproit.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ReproIt/reproit.git",
    "directory": "sdk/reproit-react-native"
  },
  "bugs": {
    "url": "https://github.com/ReproIt/reproit/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "android",
    "ios",
    "reproit-react-native.podspec",
    "react-native.config.js",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "test": "jest --watchman=false",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "reproit",
    "react-native",
    "telemetry",
    "observability",
    "state-graph",
    "crash-reporting"
  ],
  "peerDependencies": {
    "react": ">=17",
    "react-native": ">=0.64"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  }
}
