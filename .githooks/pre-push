#!/usr/bin/env bash
# Block pushing private identifiers to the public remote (see
# scripts/check-clean.sh). Runs at the last gate before anything goes public, so
# a leak is stopped BEFORE it ships, not detected after.
# Enable once per clone:  git config core.hooksPath .githooks
exec bash "$(git rev-parse --show-toplevel)/scripts/check-clean.sh"
