      "tier": "release",
      "timeoutSeconds": 1200,
      "resetStrategy": "create and boot a disposable iPhone simulator plus a generated app",
      "cleanupStrategy": "delete the simulator and remove the temporary application directory",
      "requiredOutput": [
        "iOS simulator reset: created ",
        "EXPLORE:STATE ",
        "EXPLORE:EDGE ",
        "JOURNEY DONE",
        "All tests passed",
        "iOS simulator cleanup: deleted "
      ],
      "automation": {"mode": "workflow-dispatch", "workflow": ".github/workflows/native-gates.yml", "job": "macos-flutter"}
    },
    "web-chromium": {
